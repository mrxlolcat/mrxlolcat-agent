# === Required ===
NEXT_PUBLIC_APP_URL=https://mrxlolcat-agent.vercel.app

# DashScope (Alibaba Cloud - Primary LLM Provider)
DASHSCOPE_API_KEY=sk-xxx

# Model Selection (optional, defaults to qwen-plus)
# Options: qwen-plus, qwen-turbo, qwen-max, qwen2.5-72b-instruct, qwen2.5-32b-instruct
AI_MODEL=qwen-plus

# === Optional ===

# Wallet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Farcaster / Neynar
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=
FARCASTER_NOTIFICATION_TOKEN=

# Memory (Pinecone vector storage)
PINECONE_API_KEY=

# Text-to-Speech
ELEVENLABS_API_KEY=
