# Required
NEXT_PUBLIC_APP_URL=https://mrxlolcat-agent.vercel.app

# AI Providers (At least one required)
DASHSCOPE_API_KEY=sk-xxx # Alibaba Cloud Qwen (Singapore) - Recommended for SEA users
AGENTROUTER_API_KEY=sk-xxx # Preferred (from agentrouter.org)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# AI Model Selection (optional — defaults based on provider)
# DashScope: qwen-plus, qwen-turbo, qwen-max, qwen2.5-72b-instruct
# Options: gpt-4o-mini, gpt-4o, claude-3-5-sonnet, gemini-2.0-flash
AI_MODEL=qwen-plus

# Wallet & Protocol Keys
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEYNAR_API_KEY=
PINECONE_API_KEY=
ELEVENLABS_API_KEY=

# Farcaster
FARCASTER_SIGNER_UUID=
FARCASTER_NOTIFICATION_TOKEN=
